{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-v4-pro",
    "base_url": "https://www.packyapi.com",
    "api_key_env": "sk-mYWsxUogZIPZenDg4BM88rXjcQYCjGc3Iqe2o839gdtYOkZT",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh",
      "en"
    ]
  },
  "sources": {
  "hackernews": true,       // 国际AI/科技新闻主要来源
  "reddit": {
    "enabled": true,
    "subreddits": ["MachineLearning", "artificial", "LocalLLaMA"] // AI相关板块
  },
  "rss": {
    "enabled": true,
    "feeds": [
      "https://www.jiqizhixin.com/rss", // 机器之心（国内）
      "https://www.qbitai.com/feed",    // 量子位（国内）
      "https://techcrunch.com/feed/",   // TechCrunch（国际）
      "https://www.theverge.com/ai-artificial-intelligence/rss/index.xml" // The Verge AI板块
    ]
  },
  "github": true,           // 关注AI热门开源项目动态
  "telegram": false         // 可先关闭，后续有需要再配置
}
  "filtering": {
    "ai_score_threshold": 8.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
